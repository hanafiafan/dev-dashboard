# ============================================================
#  Dev Dashboard — Environment Configuration
# ============================================================
#
# Leave EVERYTHING empty to run in DEMO MODE (data in browser
# localStorage, seeded sample data, login password = "admin").
#
# To use the real Supabase backend, fill these in.
# See supabase/SETUP.md for the full guide.
# ============================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Owner identity (optional) ---
# The email shown on the public site / used as the demo login default.
NEXT_PUBLIC_OWNER_EMAIL=hanafi.afan@gmail.com

# --- Demo login password (only used in demo mode) ---
NEXT_PUBLIC_DEMO_PASSWORD=admin

# --- Optional: real wallpaper image behind the glass UI ---
# Drop an image into the `public/` folder (e.g. public/wallpaper.jpg) and set:
#   NEXT_PUBLIC_WALLPAPER_URL=/wallpaper.jpg
# or use any external image URL. Leave empty to keep the generated macOS-style gradient.
NEXT_PUBLIC_WALLPAPER_URL=
